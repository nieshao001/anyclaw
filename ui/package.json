  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "node ./scripts/generate-workspace-snapshot.mjs && vite",
    "typecheck": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.node.json",
